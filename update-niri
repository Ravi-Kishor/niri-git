#!/usr/bin/env bash
set -euo pipefail

REPO="Ravi-Kishor/niri-git"
PKG_NAME="niri-git"

AUTO_YES=false
FORCE=false

# -------------------------------
# Parse Arguments
# -------------------------------
for arg in "$@"; do
  case "$arg" in
    -y|--yes) AUTO_YES=true ;;
    -f|--force) FORCE=true ;;
  esac
done

# -------------------------------
# Dependency Check
# -------------------------------
require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "❌ Missing: $1"
    exit 1
  }
}

for cmd in curl jq pacman sudo aria2c vercmp sed awk; do
  require "$cmd"
done

# -------------------------------
# Version
# -------------------------------
get_installed_version() {
  pacman -Q "$PKG_NAME" 2>/dev/null | awk '{print $2}' || echo ""
}

INSTALLED_VERSION="$(get_installed_version)"

echo "------------------------------------------"
echo "  Niri Installer (Zen3 build)"
echo "------------------------------------------"
echo "Local:   ${INSTALLED_VERSION:-Not Installed}"
echo "📡 Fetching latest release..."

RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest")"

# ✅ Correct asset match (real output)
ASSET_URL="$(echo "$RELEASE_JSON" | jq -r '
  .assets[]
  | select(.name | test("^niri-git-.*-x86_64\\.pkg\\.tar\\.zst$"))
  | .browser_download_url
' | head -n1)"

if [[ -z "$ASSET_URL" || "$ASSET_URL" == "null" ]]; then
  echo "❌ No package found in release."
  exit 1
fi

PKG_FILE="$(basename "$ASSET_URL")"

# Clean version extraction
LATEST_VERSION="$(echo "$PKG_FILE" | sed -E 's/^niri-git-(.*)-x86_64\.pkg\.tar\.zst/\1/')"

echo "Remote:  $LATEST_VERSION"
echo "------------------------------------------"

# Compare versions
UP_TO_DATE=false
if [[ -n "$INSTALLED_VERSION" ]]; then
  if [[ "$(vercmp "$INSTALLED_VERSION" "$LATEST_VERSION")" -ge 0 ]]; then
    UP_TO_DATE=true
  fi
fi

# -------------------------------
# Menu
# -------------------------------
if [[ "$AUTO_YES" == "false" && "$FORCE" == "false" ]]; then
  echo "Choose an action:"
  if [[ "$UP_TO_DATE" == "true" ]]; then
    echo "1) Update (Already latest: $INSTALLED_VERSION)"
  else
    echo "1) Update to $LATEST_VERSION"
  fi
  echo "2) Force reinstall"
  echo "3) Cancel"

  read -rp "Enter choice (1/2/3): " CHOICE

  case "$CHOICE" in
    1)
      if [[ "$UP_TO_DATE" == "true" ]]; then
        echo "✅ Already up to date."
        exit 0
      fi
      ;;
    2) FORCE=true ;;
    *) echo "Cancelled."; exit 0 ;;
  esac
fi

if [[ "$UP_TO_DATE" == "true" && "$FORCE" == "false" ]]; then
  echo "✅ Already up to date."
  exit 0
fi

# -------------------------------
# Conflict handling
# -------------------------------
remove_if_installed() {
  pacman -Qq "$1" &>/dev/null && sudo pacman -Rns --noconfirm "$1" || true
}

# Remove official versions only
for pkg in niri niri-bin; do
  remove_if_installed "$pkg"
done

# Only remove self if forcing
if [[ "$FORCE" == "true" ]]; then
  remove_if_installed "$PKG_NAME"
fi

# -------------------------------
# Download & install
# -------------------------------
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
cd "$TMP_DIR"

echo "⬇️ Downloading..."
aria2c -x 12 -s 12 -k 1M "$ASSET_URL"

echo "📦 Installing..."
sudo pacman -U --noconfirm "$PKG_FILE"

echo "------------------------------------------"
echo "✅ $PKG_NAME $LATEST_VERSION installed!"
echo "------------------------------------------"
