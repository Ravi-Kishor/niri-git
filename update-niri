#!/usr/bin/env bash
set -euo pipefail

# --- CONFIGURATION ---
REPO="Ravi-Kishor/niri-git"
PKG_NAME="niri-git"
# Matches the new naming: znver3-thin.pkg.tar.zst
ARCH_PATTERN="znver3-thin.pkg.tar.zst"

AUTO_YES=false
FORCE=false

# -------------------------------
# Parse Arguments
# -------------------------------
for arg in "$@"; do
  case "$arg" in
    -y|--yes) AUTO_YES=true ;;
    -f|--force) FORCE=true ;;
  esac
done

# -------------------------------
# Dependency Check
# -------------------------------
require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "❌ Required command '$1' not found."
    exit 1
  }
}

for cmd in curl jq pacman sudo aria2c vercmp sed awk; do
  require "$cmd"
done

# -------------------------------
# Version Logic
# -------------------------------
get_installed_version() {
  pacman -Q "$PKG_NAME" 2>/dev/null | awk '{print $2}' || echo ""
}

INSTALLED_VERSION="$(get_installed_version)"

echo "------------------------------------------"
echo "  Niri-Git Zen 3 (Thin LTO) Installer"
echo "------------------------------------------"
echo "Local:   ${INSTALLED_VERSION:-Not Installed}"
echo "📡 Checking GitHub..."

RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest")"
ASSET_URL="$(echo "$RELEASE_JSON" | jq -r \
  ".assets[] | select(.name | contains(\"znver3\")) | .browser_download_url" \
  | head -n1)"

if [[ -z "$ASSET_URL" || "$ASSET_URL" == "null" ]]; then
  echo "❌ Error: No Zen 3 package found in latest release."
  exit 1
fi

PKG_FILE="$(basename "$ASSET_URL")"
LATEST_VERSION=$(echo "$PKG_FILE" | sed -E "s/^${PKG_NAME}-(.*)-znver3.*\.pkg\.tar\.zst/\1/")

echo "Remote:  $LATEST_VERSION"
echo "------------------------------------------"

# Compare
UP_TO_DATE=false
if [[ -n "$INSTALLED_VERSION" ]]; then
  if [[ "$(vercmp "$INSTALLED_VERSION" "$LATEST_VERSION")" -ge 0 ]]; then
    UP_TO_DATE=true
  fi
fi

# -------------------------------
# Interactive Menu (RESTORED)
# -------------------------------
if [[ "$AUTO_YES" == "false" && "$FORCE" == "false" ]]; then
  echo "Choose an action:"
  if [[ "$UP_TO_DATE" == "true" ]]; then
    echo "1) Update (Already latest: $INSTALLED_VERSION)"
  else
    echo "1) Update to $LATEST_VERSION"
  fi
  echo "2) Force reinstall"
  echo "3) Cancel"
  read -rp "Enter choice (1/2/3): " CHOICE

  case "$CHOICE" in
    1) # Standard Update
        if [[ "$UP_TO_DATE" == "true" ]]; then
          echo "✅ Already up to date. Use choice '2' to force."
          exit 0
        fi
        ;;
    2) # Force Reinstall
        FORCE=true 
        ;;
    *) # Cancel
        echo "Cancelled."; exit 0 
        ;;
  esac
fi

# Final check for skip (if not forced)
if [[ "$UP_TO_DATE" == "true" && "$FORCE" == "false" ]]; then
    echo "✅ Already up to date."
    exit 0
fi

# -------------------------------
# Conflict Removal
# -------------------------------
remove_conflict() {
  if pacman -Qq "$1" >/dev/null 2>&1; then
    echo "Removing conflict: $1"
    sudo pacman -Rns --noconfirm "$1" || true
  fi
}

# Cleanup standard niri before installing optimized version
# We only remove $PKG_NAME if FORCE is true, otherwise we let pacman -U handle the upgrade
for conflict in niri niri-bin; do
  remove_conflict "$conflict"
done

if [[ "$FORCE" == "true" ]]; then
  remove_conflict "$PKG_NAME"
fi

# -------------------------------
# Download & Install
# -------------------------------
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
cd "$TMP_DIR"

echo "⬇️ Downloading: $PKG_FILE"
aria2c -x 12 -s 12 -j 12 -k 1M "$ASSET_URL"

echo "📦 Installing..."
sudo pacman -U --noconfirm "$PKG_FILE"

echo "------------------------------------------"
echo "✅ $PKG_NAME $LATEST_VERSION installed."
echo "------------------------------------------"
